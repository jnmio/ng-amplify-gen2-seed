{
  "name": "ng-amplify-gen2-seed",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "sandbox": "npx ampx sandbox",
    "sandbox:dev": "concurrently \"npm run dev\" \"npx ampx sandbox\"",
    "dev": "ng serve --open",
    "help": "echo '📚 Available Scripts:' && echo '• npm run dev - Start development with auto-open browser' && echo '• npm start - Start development server' && echo '• npm run sandbox - Start Amplify Gen 2 cloud sandbox' && echo '• npm run sandbox:dev - Start both dev server and sandbox' && echo '• npm run build:prod - Build for production' && echo '• npm test - Run unit tests' && echo '• npm run help - Show this help' && echo '' && echo '📖 Full guide: NPM_SCRIPTS_GUIDE.md'",
    "clean": "rm -rf node_modules package-lock.json && npm install",
    "check": "echo 'Amplify Gen 2 uses cloud sandbox for development.' && echo 'Run: npm run sandbox (in separate terminal)' && echo 'Then: npm run dev' && echo '' && echo '✅ Check for amplify_outputs.json in project root'"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "@aws-amplify/api": "^6.3.15",
    "@aws-amplify/cli": "^14.0.0",
    "@aws-amplify/ui-angular": "^5.1.2",
    "aws-amplify": "^6.15.4",
    "bootstrap": "^5.3.7",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.15",
    "@angular/cli": "^19.2.15",
    "@angular/compiler-cli": "^19.2.0",
    "@aws-amplify/backend": "^1.16.1",
    "@aws-amplify/backend-cli": "^1.8.0",
    "@types/jasmine": "~5.1.0",
    "aws-cdk-lib": "^2.204.0",
    "concurrently": "^7.6.0",
    "constructs": "^10.4.2",
    "esbuild": "^0.25.8",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
